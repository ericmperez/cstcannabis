#: page-templates/template-course.php
msgid "Colaboración entre agencias gubernamentales para promover una cultura de uso responsable."
msgstr "Collaboration between government agencies to promote a culture of responsible use."

#: page-templates/template-course.php
msgid "Educación preventiva"
msgstr "Preventive education"

#: page-templates/template-course.php
msgid "Formación obligatoria para garantizar la seguridad vial de pacientes y conductores."
